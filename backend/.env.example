# Backend 로컬 실행용 환경 변수 (Docker 미사용 시)
# 이 파일을 복사하여 .env 를 생성하세요: cp .env.example .env

# 공유 PostgreSQL (dev_writer 계정으로 edufit_dev 접속)
DATABASE_URL=postgresql://dev_writer:<password>@***REMOVED***:5432/edufit_dev

# 로컬 격리 DB 사용 시 (docker-compose.yml의 edufit-db)
# DATABASE_URL=postgresql://postgres:<password>@localhost:5433/edufit_dev

# 운영 DB 접속 (edufit_svc 서비스 계정)
# DATABASE_URL=postgresql://edufit_svc:<password>@***REMOVED***:5432/edufit

CORS_ORIGINS=http://localhost:4070
DEBUG=true
LOG_LEVEL=DEBUG
