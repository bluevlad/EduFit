# EduFit Docker 환경 변수
# 이 파일을 복사하여 .env 를 생성하세요: cp .env.example .env
# .env 파일은 git에 포함되지 않습니다.

# ── 로컬 개발 (docker-compose.yml, 격리 DB) ──
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=edufit_dev
DB_HOST=db
DB_PORT=5433
CORS_ORIGINS=http://localhost:4070
DEBUG=true
LOG_LEVEL=INFO

# ── 운영 (docker-compose.prod.yml, 공유 PostgreSQL) ──
# DB_USER=<service_account>
# DB_PASSWORD=<password>
# DB_NAME=<dbname>
# DB_HOST=<host>
# DB_PORT=5432
# CORS_ORIGINS=http://localhost:4070,https://insight.unmong.com
# DEBUG=false
# LOG_LEVEL=INFO

# ── Google OAuth (ID 토큰 방식) ──
GOOGLE_CLIENT_ID=
SUPER_ADMIN_EMAILS=
JWT_SECRET_KEY=change-me-in-production

# ── AI Crawler ──
NAVER_ID=your_naver_id
NAVER_PW=your_naver_password
APP_MODE=full
CRAWL_LIMIT=50

# ── SMTP ──
SMTP_USER=
SMTP_PASSWORD=
