# EduFit Docker 환경 변수
# 이 파일을 복사하여 .env 를 생성하세요: cp .env.example .env
# .env 파일은 git에 포함되지 않습니다.

# ── Database ──
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=edufit_dev
DB_HOST=db
DB_PORT=5433

# ── Backend ──
CORS_ORIGINS=http://localhost:4070
DEBUG=true
LOG_LEVEL=INFO

# ── Production 전용 (docker-compose.prod.yml) ──
# DB_USER=edufit_svc
# DB_PASSWORD=your_production_password_here
# DB_NAME=edufit
# DB_HOST=postgresql
# DB_PORT=5432
# CORS_ORIGINS=http://localhost:4070,http://***REMOVED***:4070
# DEBUG=false
# LOG_LEVEL=INFO
